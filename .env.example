# Environment variables for Autonomous AI Cyber Defense Agent
# Copy this file to .env and customize values

# ── Server ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
DEBUG=false

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:////app/data/db/cyber_defense.db

# ── Ollama LLM ────────────────────────────────────────────────
OLLAMA_API_URL=http://ollama:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# ── Qdrant Vector DB (for RAG / Threat Intelligence) ─────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── Defense Settings ─────────────────────────────────────────
# Set DRY_RUN_MODE=true to log without actually blocking IPs
ENABLE_AUTO_BLOCK=true
DRY_RUN_MODE=false

# Comma-separated IPs that should never be blocked
WHITELIST_IPS=

# ── Detection Thresholds ─────────────────────────────────────
BRUTE_FORCE_THRESHOLD=5
BRUTE_FORCE_WINDOW=60

# ── Monitoring ────────────────────────────────────────────────
NGINX_LOG_PATH=/var/log/nginx/access.log

# ── Dashboard ─────────────────────────────────────────────────
BACKEND_URL=http://backend:8000

# ── Vulnerability / Threat Intelligence ─────────────────────
SCAN_TARGET=testapp
NVD_API_KEY=
