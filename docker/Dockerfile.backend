FROM python:3.11-slim

LABEL maintainer="Autonomous AI Cyber Defense Agent"
LABEL description="FastAPI backend with iptables support"

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    iptables \
    sudo \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Allow app user to run iptables without password
RUN useradd -m -u 1000 appuser && \
    echo "appuser ALL=(ALL) NOPASSWD: /sbin/iptables, /usr/sbin/iptables" >> /etc/sudoers

WORKDIR /app

# Install Python dependencies first (for layer caching)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY backend/ ./backend/
COPY config/ ./config/

# Create data directories
RUN mkdir -p /app/data/logs /app/data/db /app/data/models && \
    touch /app/data/logs/access.log && \
    chown -R appuser:appuser /app

USER appuser

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
