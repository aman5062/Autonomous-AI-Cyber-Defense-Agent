FROM python:3.11-slim

# ping + arp tools needed for network scanning
RUN apt-get update && apt-get install -y \
    iputils-ping \
    net-tools \
    iproute2 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY wifi_guard/requirements.txt ./requirements.txt
RUN pip install --upgrade pip && \
    pip install -r requirements.txt

COPY wifi_guard/ ./wifi_guard/

EXPOSE 8503

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8503/health')" || exit 1

CMD ["uvicorn", "wifi_guard.main:app", "--host", "0.0.0.0", "--port", "8503"]
