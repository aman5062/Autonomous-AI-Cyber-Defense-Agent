FROM python:3.11-slim

WORKDIR /app

RUN pip install --upgrade pip && \
    pip install flask>=3.0.0 requests>=2.32.0

COPY test_app/ ./test_app/

# Initialize DB at build time using the Docker path
ENV TEST_DB_PATH=/app/test_app/test.db
RUN python test_app/init_db.py

EXPOSE 5000

CMD ["python", "test_app/vulnerable_app.py"]
